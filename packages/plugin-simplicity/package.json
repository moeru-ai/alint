{
  "name": "@alint-js/plugin-simplicity",
  "type": "module",
  "version": "0.1.1",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@alint-js/agent-apeira": "workspace:*",
    "@alint-js/core": "workspace:*",
    "@alint-js/plugin": "workspace:*",
    "@alint-js/tools-fs": "workspace:*",
    "@moeru/std": "catalog:",
    "minimatch": "catalog:",
    "pathe": "catalog:",
    "tree-sitter-wasms": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "valibot": "catalog:",
    "web-tree-sitter": "catalog:"
  }
}
