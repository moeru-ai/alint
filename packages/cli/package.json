{
  "name": "@alint-js/cli",
  "type": "module",
  "version": "0.0.11",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "alint": "./dist/bin/index.mjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "alint": "node ./dist/bin/index.mjs",
    "build": "tsdown",
    "build:binary": "tsdown --config tsdown.binary.config.ts --config-loader unrun",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "@alint-js/config": "workspace:*",
    "@alint-js/core": "workspace:*",
    "@clack/prompts": "catalog:",
    "@moeru/std": "catalog:",
    "cac": "catalog:",
    "cli-spinners": "catalog:",
    "gitignore-fs": "catalog:",
    "minimatch": "catalog:",
    "pathe": "catalog:",
    "table": "catalog:",
    "tinyrainbow": "catalog:"
  },
  "devDependencies": {
    "@pnpm/find-workspace-dir": "catalog:",
    "@types/node": "catalog:",
    "mlly": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:vitest"
  }
}
