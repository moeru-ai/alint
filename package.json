{
  "name": "@alint-js/root",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.8.0",
  "license": "MIT",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "vitest",
    "test:run": "vitest run",
    "lint:fix": "eslint --cache . --fix",
    "lint": "eslint --cache .",
    "spellcheck": "cspell .",
    "typecheck": "pnpm -rF=\"./packages/*\" -F=\"./apps/*\" -F=\"./docs\" --parallel typecheck",
    "up": "taze -w -r -I && pnpm prune && pnpm dedupe",
    "nolyfill": "pnpm dlx nolyfill",
    "knip": "knip"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@arethetypeswrong/core": "catalog:",
    "@moeru/eslint-config": "catalog:",
    "@alint-js/plugin-example": "workspace:*",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:vitest",
    "bumpp": "catalog:",
    "cac": "catalog:",
    "cspell": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "knip": "catalog:",
    "@alint-js/cli": "workspace:*",
    "nano-staged": "catalog:",
    "oxc-minify": "catalog:",
    "oxlint": "catalog:",
    "publint": "catalog:",
    "rollup": "catalog:",
    "simple-git-hooks": "catalog:",
    "taze": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "unplugin-raw": "catalog:",
    "unplugin-unused": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:vitest"
  }
}
