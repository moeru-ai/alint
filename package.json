{
  "name": "@alint-js/root",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.13.0",
  "license": "MIT",
  "scripts": {
    "alint": "pnpm -F @alint-js/cli run alint",
    "build": "pnpm -r run build",
    "test": "vitest",
    "test:run": "vitest run",
    "docs:sync-readme": "tsx scripts/sync-cli-readme.ts",
    "docs:toc": "doctoc --github --title \"## Table of Contents\" --maxlevel=2 README.md",
    "docs:update": "pnpm docs:toc && pnpm docs:sync-readme",
    "lint:fix": "eslint --cache . --fix",
    "lint": "eslint --cache .",
    "lint:alint": "pnpm -F @alint-js/cli exec tsx src/bin/index.ts ../..",
    "spellcheck": "cspell .",
    "typecheck": "pnpm -rF=\"./packages/*\" -F=\"./apps/*\" -F=\"./docs\" --parallel typecheck",
    "publish:lib": "pnpm -r publish --access public --no-git-checks",
    "up": "taze -w -r -I && pnpm prune && pnpm dedupe",
    "nolyfill": "pnpm dlx nolyfill",
    "knip": "knip"
  },
  "devDependencies": {
    "@alint-js/cli": "workspace:*",
    "@alint-js/config": "workspace:*",
    "@alint-js/core": "workspace:*",
    "@alint-js/plugin": "workspace:*",
    "@alint-js/plugin-example-python": "workspace:*",
    "@alint-js/plugin-js": "workspace:*",
    "@antfu/eslint-config": "catalog:",
    "@arethetypeswrong/core": "catalog:",
    "@moeru/eslint-config": "catalog:",
    "@types/node": "catalog:",
    "@vitest/coverage-v8": "catalog:vitest",
    "bumpp": "catalog:",
    "cac": "catalog:",
    "cspell": "catalog:",
    "doctoc": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-oxlint": "catalog:",
    "knip": "catalog:",
    "nano-staged": "catalog:",
    "oxc-minify": "catalog:",
    "oxlint": "catalog:",
    "publint": "catalog:",
    "rollup": "catalog:",
    "simple-git-hooks": "catalog:",
    "taze": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "unplugin-raw": "catalog:",
    "unplugin-unused": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:vitest"
  }
}
